# Copy this file to ".env" and fill in a value ONLY if you want /process to use
# the optional ai_vision engine instead of the default, free, offline rule_based
# engine. This mirrors the same "bring your own key" pattern used by the
# underlying receipt-invoice-extractor pipeline vendored in extractor/.
#
# Never commit your real .env — it is gitignored by default.

# Only used by the ai_vision engine (Google Gemini). Get a FREE key at
# https://aistudio.google.com/apikey (no card needed).
AI_API_KEY=

# Optional: override the model name. Defaults to gemini-flash-latest (always the
# current free flash model) if left blank.
AI_MODEL=

# Note: to actually use ai_vision, pass engine=ai_vision as a query param on the
# /process request (see api/main.py), or change the default in processor.py.
